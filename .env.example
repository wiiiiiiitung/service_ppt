# Service PPT Generator Environment Variables

# Flask session secret key (for persistent sessions across restarts)
# Generate with: python3 -c "import secrets; print(secrets.token_hex())"
# If not set, a random key is generated each restart (sessions are invalidated)
FLASK_SECRET_KEY=your_secret_key_here_at_least_24_chars

# Vercel deployment indicator (set automatically by Vercel)
# VERCEL=1
